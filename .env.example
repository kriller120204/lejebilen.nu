# Database (Neon, Supabase eller lokal PostgreSQL)
DATABASE_URL="postgresql://user:password@host:5432/lejebilen"

# Admin-login (plaintext password — brug noget sikkert i produktion)
ADMIN_PASSWORD="skift-mig"
ADMIN_SECRET="en-lang-tilfaeldig-streng-til-session-cookie"

# QuickPay (https://manage.quickpay.net → Settings → API Keys)
QUICKPAY_API_KEY="din-quickpay-api-key"
QUICKPAY_PRIVATE_KEY="din-quickpay-private-key"
QUICKPAY_MERCHANT_ID="din-merchant-id"

# Resend (https://resend.com → API Keys)
RESEND_API_KEY="re_..."
EMAIL_FROM="Lejebilen.nu <booking@lejebilen.nu>"

# 46elks SMS (https://46elks.com → Account → API credentials)
FORTYSIX_ELKS_USERNAME="din-46elks-username"
FORTYSIX_ELKS_PASSWORD="din-46elks-password"
SMS_FROM="Lejebilen"

# Penneo digital underskrift (https://penneo.com → Developers)
PENNEO_CLIENT_ID="din-penneo-client-id"
PENNEO_CLIENT_SECRET="din-penneo-client-secret"
PENNEO_ENV="sandbox"   # eller "production"

# e-conomic (https://apps.e-conomic.com → Apps → Token)
ECONOMIC_SECRET_TOKEN="din-economic-secret-token"
ECONOMIC_AGREEMENT_GRANT_TOKEN="din-economic-agreement-grant-token"

# App URL (bruges i webhooks og e-mails)
NEXT_PUBLIC_URL="http://localhost:3000"
